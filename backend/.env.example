# ---- Server ----
PORT=5000
CLIENT_URL=http://localhost:5173

# ---- MongoDB Atlas ----
# Get this from MongoDB Atlas -> Connect -> Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/interviewpilot?retryWrites=true&w=majority

# ---- Firebase Admin (server-side token verification) ----
# Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# Paste the values from the downloaded JSON file below.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Keep the \n characters literally - they get converted to real newlines in config/firebaseAdmin.js
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ---- Gemini API ----
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
